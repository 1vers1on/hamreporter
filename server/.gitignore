# ---------------------------------------------------------------------------
# Gradle
# ---------------------------------------------------------------------------
# Ignore Gradle project-specific cache directory
.gradle
# Ignore Gradle build output directory
build/
# Ignore Kotlin plugin data
.kotlin
# Gradle wrapper / local caches
.gradletasknamecache
gradle-app.setting
# Local Gradle configuration (machine-specific, should not be committed)
gradle.properties.local

# ---------------------------------------------------------------------------
# Java / JVM
# ---------------------------------------------------------------------------
*.class
*.jar
*.war
*.ear
*.nar
# Virtual machine crash logs
hs_err_pid*
replay_pid*
# JVM dumps
*.hprof
# Compiled output
out/
target/
bin/

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
logs/

# ---------------------------------------------------------------------------
# IntelliJ IDEA
# ---------------------------------------------------------------------------
.idea/
*.iml
*.ipr
*.iws
# Generated files in older IDEA layouts
.idea_modules/
atlassian-ide-plugin.xml

# ---------------------------------------------------------------------------
# Eclipse
# ---------------------------------------------------------------------------
.classpath
.project
.settings/
.metadata/
.apt_generated/
.factorypath
.springBeans
.recommenders/
bin/

# ---------------------------------------------------------------------------
# VS Code
# ---------------------------------------------------------------------------
.vscode/
*.code-workspace

# ---------------------------------------------------------------------------
# NetBeans
# ---------------------------------------------------------------------------
nbproject/private/
nbbuild/
dist/
nbdist/
.nb-gradle/

# ---------------------------------------------------------------------------
# Environment / secrets
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key
secrets.properties
local.properties

# ---------------------------------------------------------------------------
# macOS
# ---------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ---------------------------------------------------------------------------
# Windows
# ---------------------------------------------------------------------------
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ---------------------------------------------------------------------------
